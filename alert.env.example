# Config REFERENCE for the ringback-alert MCP (server.py).
# NOTE: this file is NOT auto-loaded. server.py reads the process environment,
# so copy the variables you need into your MCP client's "env" block (Claude
# Desktop config) or `claude mcp add --env KEY=VALUE ...` flags.

# Comma list of backends: ntfy, pushover, call.  (Aliases: "both"=ntfy+pushover,
# "all"=everything.)  e.g. ALERT_CHANNEL=ntfy,call
ALERT_CHANNEL=ntfy

# ---- ntfy (free push) ----
# Use a long, random, hard-to-guess topic — anyone who knows it can read/publish.
NTFY_URL=https://ntfy.sh/CHANGE-ME-to-a-random-topic
# Only needed when self-hosting ntfy with auth (blank for public ntfy.sh):
NTFY_TOKEN=

# ---- Pushover ($5 one-time, true iOS Critical Alerts) ----
# App token from https://pushover.net/apps/build ; user key from the dashboard.
PUSHOVER_TOKEN=
PUSHOVER_USER=

# ---- SIP ring + chat message (free, via baresip + a Linphone account) ----
# The SIP username/password live in SIP_CONFIG_DIR/accounts, NOT here.
SIP_BARESIP_BIN=/opt/homebrew/bin/baresip
SIP_CONFIG_DIR=/path/to/your/.baresip-phone-alert
SIP_CALLEE=sip:YOURUSER@sip.linphone.org
SIP_RING_SECONDS=30
# A call only fires at this severity and above (so info/warn don't ring you):
CALL_MIN_SEVERITY=critical

# ---- rate-limit guard (optional) ----
ALERT_MAX_PER_WINDOW=5
ALERT_WINDOW_SEC=60
