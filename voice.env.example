# Config for the ringback-voice MCP. setup.sh copies this to `voice.env` (gitignored);
# run_voice_mcp.sh sources voice.env automatically. Only the 3 REQUIRED vars below
# need filling in — everything else has a sensible default.

# ===== REQUIRED — your SIP account =====
# Free account: https://subscribe.linphone.org  (or "Create account" in the Linphone app).
# Your address is sip:<username>@sip.linphone.org
export VOICE_SIP_ID="sip:YOURUSER@sip.linphone.org"
export VOICE_SIP_USER="YOURUSER"
export VOICE_SIP_PASS="YOUR_SIP_PASSWORD"

# ===== OPTIONAL — sensible defaults, change only if needed =====
# Who to call (defaults to VOICE_SIP_ID — i.e. it calls your own phone):
# export VOICE_SIP_CALLEE="sip:YOURUSER@sip.linphone.org"
# SIP registrar/proxy (default works for sip.linphone.org):
# export VOICE_SIP_PROXY="sip:sip.linphone.org;transport=tls"
# Caller-ID name shown on your phone when the agent calls (default: bare SIP user):
# export VOICE_DISPLAY_NAME="My Claude"
# Speech-to-text model — base.en=fast/rough, small.en=balanced(default), medium.en=accurate/slow:
# export WHISPER_MODEL="$HOME/.whisper-models/ggml-small.en.bin"

# ===== OPTIONAL — toolchain paths (only if run_voice_mcp.sh auto-detection fails) =====
# export PJPROJECT_DIR="$HOME/build/pjproject-2.17"
# export PYTHON_BIN="$(command -v python3)"
# export OPENSSL_PREFIX="$(brew --prefix openssl@3)"
