# Config for the ringback-voice MCP. setup.sh copies this to `voice.env` (gitignored);
# the launcher sources it automatically (run_voice_mcp.sh on macOS, run_voice_mcp.py on
# Linux/Windows). Only the 3 REQUIRED vars below need filling in — the rest have defaults.

# ===== REQUIRED — your SIP account =====
# Free account: https://subscribe.linphone.org  (or "Create account" in the Linphone app).
# Your address is sip:<username>@sip.linphone.org
export VOICE_SIP_ID="sip:YOURUSER@sip.linphone.org"
export VOICE_SIP_USER="YOURUSER"
export VOICE_SIP_PASS="YOUR_SIP_PASSWORD"

# ===== OPTIONAL — sensible defaults, change only if needed =====
# Who to call (defaults to VOICE_SIP_ID — i.e. it calls your own phone):
# export VOICE_SIP_CALLEE="sip:YOURUSER@sip.linphone.org"
# SIP registrar/proxy (default works for sip.linphone.org):
# export VOICE_SIP_PROXY="sip:sip.linphone.org;transport=tls"
# Caller-ID name shown on your phone when the agent calls (default: bare SIP user):
# export VOICE_DISPLAY_NAME="My Claude"
# STUN server — advertise our PUBLIC address so two-way audio works behind NAT (REQUIRED when
# running in Docker; not needed for a native/host-network setup). Blank = off:
# export VOICE_STUN="stun.l.google.com:19302"   # or stun.linphone.org
# Speech-to-text model — base.en=fast/rough, small.en=balanced(default), medium.en=accurate/slow:
# export WHISPER_MODEL="$HOME/.whisper-models/ggml-small.en.bin"

# ===== OPTIONAL — text-to-speech (cross-platform) =====
# Engine: auto (default; Piper if installed, else the OS voice) | piper | say | espeak | sapi
# export VOICE_TTS="auto"
# Piper voice model (cross-platform default voice; needs the matching .onnx.json beside it):
# export VOICE_PIPER_MODEL="$HOME/.piper-voices/en_US-lessac-medium.onnx"
# Custom TTS — any command that writes a WAV; {text} and {out} are substituted:
# export VOICE_TTS_CMD="mytts --text {text} --out {out}"
# Force pjsua2 null audio device (auto=on except macOS; required headless): 1 | 0 | auto
# export VOICE_NULL_AUDIO="auto"
# Watchdog presence override (Wayland/headless where idle can't be read): present | absent
# export RINGBACK_PRESENCE="absent"

# ===== OPTIONAL — silence diagnostics =====
# Every listen turn already logs ONE summary line to stderr (lands in the MCP client's
# logs): exit reason, max RMS vs threshold, voiced polls, recorded bytes. These add more:
# Chatty detail — log each transcript the hallucination filter discards:
# export VOICE_DEBUG=1
# Keep the recorded audio of any SILENT turn for replay (default dir: /tmp/ringback-debug):
# export VOICE_DEBUG_KEEP_WAV=1
# export VOICE_DEBUG_WAV_DIR="/tmp/ringback-debug"

# ===== OPTIONAL — toolchain paths (only if launcher auto-detection fails) =====
# export PJPROJECT_DIR="$HOME/build/pjproject-2.17"
# export PYTHON_BIN="$(command -v python3)"
# export OPENSSL_PREFIX="$(brew --prefix openssl@3)"
