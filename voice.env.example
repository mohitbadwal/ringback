# Config for the phone-voice MCP. Copy to `voice.env` (gitignored) and fill in.
# run_voice_mcp.sh sources voice.env automatically.

# --- your SIP account (a free sip.linphone.org account works great) ---
export VOICE_SIP_ID="sip:YOURUSER@sip.linphone.org"
export VOICE_SIP_CALLEE="sip:YOURUSER@sip.linphone.org"   # who to call (usually = your own ID)
export VOICE_SIP_USER="YOURUSER"
export VOICE_SIP_PASS="YOUR_SIP_PASSWORD"
export VOICE_SIP_PROXY="sip:sip.linphone.org;transport=tls"

# --- speech-to-text model (downloaded by setup.sh) ---
# base.en = fastest/roughest, small.en = good balance, medium.en = most accurate/slowest
export WHISPER_MODEL="$HOME/.whisper-models/ggml-small.en.bin"

# --- toolchain paths (only set if auto-detection in run_voice_mcp.sh fails) ---
# export PJPROJECT_DIR="$HOME/build/pjproject-2.17"
# export PYTHON_BIN="$(command -v python3)"
# export OPENSSL_PREFIX="$(brew --prefix openssl@3)"
